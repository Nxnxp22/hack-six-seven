generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model DecodingRule {
  id          Int    @id @default(autoincrement())
  difficulty  String
  rule_number Int
  description String

  @@map("decoding_rules")
}

model CriticalTemplate {
  id         Int    @id @default(autoincrement())
  difficulty String @unique
  template   String

  @@map("critical_templates")
}

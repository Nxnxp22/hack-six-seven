generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model MorseChallenge {
  id         String   @id @default(uuid())
  word       String
  category   String   @default("general")
  difficulty String   @default("easy")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
}
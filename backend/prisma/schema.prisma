generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model DecodingRule {
  id          Int    @id @default(autoincrement())
  difficulty  String
  rule_number Int
  description String

  @@map("decoding_rules")
}

model CriticalTemplate {
  id         Int    @id @default(autoincrement())
  difficulty String @unique
  template   String

  @@map("critical_templates")
}

model ModuleStability {
  id             Int      @id @default(autoincrement())
  moduleId       String   @unique  // e.g. "powerOverload"
  startedAt      DateTime @default(now())
  bonusStability Int      @default(0)

  @@map("module_stability")
}

model GameCoins {
  id      Int @id @default(autoincrement())
  balance Int @default(100)

  @@map("game_coins")
}

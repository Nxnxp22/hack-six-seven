generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model GameState {
  id                     String   @id @default(cuid())
  coins                  Int      @default(100)
  securityStability      Int      @default(100) // owned by Module 04
  powerStability         Int      @default(100) // owned by Module 01
  reactorStability       Int      @default(100) // owned by Module 02
  communicationStability Int      @default(100) // owned by Module 03
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

// ─── Puzzle 4 (Password Puzzle) : Security Lockdown ────────────────────────────────────────────

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model PasswordPuzzle {
  id         String          @id @default(cuid())
  title      String
  difficulty Difficulty
  clueText   String
  answer     String
  timeLimit  Int             @default(90) // seconds: EASY=120, MEDIUM=90, HARD=60
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  hints      PuzzleHint[]
  attempts   PuzzleAttempt[]
}

model PuzzleHint {
  id        String         @id @default(cuid())
  puzzleId  String
  puzzle    PasswordPuzzle @relation(fields: [puzzleId], references: [id])
  hintText  String
  order     Int
  coinCost  Int
  createdAt DateTime       @default(now())
}

model PuzzleAttempt {
  id              String         @id @default(cuid())
  puzzleId        String
  puzzle          PasswordPuzzle @relation(fields: [puzzleId], references: [id])
  correct         Boolean
  timeTaken       Int
  hintsUsed       Int            @default(0)
  coinsSpentHints Int            @default(0)
  coinsChange     Int
  stabilityChange Int
  createdAt       DateTime       @default(now())
}
